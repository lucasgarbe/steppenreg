# Application Configuration
# ============================================================================
# The name of your event (displayed in emails and the admin panel)
APP_NAME=Steppenreg

# Environment: local, staging, production
APP_ENV=local

# Generate with: php artisan key:generate
APP_KEY=

# Debug mode - MUST be false in production
APP_DEBUG=true

# Your application URL (update for production)
APP_URL=http://localhost

# Timezone for your event (default: Europe/Berlin)
APP_TIMEZONE=Europe/Berlin

# Primary language for your event (de=German, en=English)
APP_LOCALE=de

# Fallback language if translation is missing
APP_FALLBACK_LOCALE=en

# Locale for generating fake data in development
APP_FAKER_LOCALE=de_DE

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# Logging Configuration
# ============================================================================
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Docker / Laravel Sail Configuration
# ============================================================================
# IMPORTANT: Set these to match your host user to avoid permission issues
# On macOS: Run `id -u` and `id -g` to get your user/group IDs
# On Linux: Usually 1000/1000
# On Windows (WSL2): Usually 1000/1000
WWWUSER=1000
WWWGROUP=1000

# Sail port mappings (change if ports are already in use)
APP_PORT=80
VITE_PORT=5173
FORWARD_DB_PORT=5432

# Database Configuration
# ============================================================================
# Database type: Use 'pgsql' for Docker, or 'sqlite' for simple local dev
DB_CONNECTION=pgsql

# For Docker: Use service name 'pgsql' as host
# For local development without Docker: Use '127.0.0.1'
DB_HOST=pgsql
DB_PORT=5432

# Change these for your event instance
DB_DATABASE=steppenreg
DB_USERNAME=postgres
DB_PASSWORD=password

# Session Configuration
# ============================================================================
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Broadcasting, Filesystem & Queue Configuration
# ============================================================================
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# Cache Configuration
# ============================================================================
CACHE_STORE=database
# CACHE_PREFIX=

# Redis Configuration (Optional - currently not used)
# ============================================================================
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Memcached Configuration (Optional - currently not used)
# ============================================================================
MEMCACHED_HOST=127.0.0.1

# Mail Configuration
# ============================================================================
# For Docker development: Use 'log' or 'mailpit'
# For production: Use 'smtp' with your mail server details
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null

# IMPORTANT: Update these for your event
MAIL_FROM_ADDRESS="registration@yourevent.com"
MAIL_FROM_NAME="${APP_NAME}"

# Maximum number of emails to send per minute (default: 20)
# Adjust based on your email provider's limits
MAIL_RATE_LIMIT_PER_MINUTE=20

# AWS Configuration (Optional - for file storage)
# ============================================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Frontend Configuration
# ============================================================================
VITE_APP_NAME="${APP_NAME}"

# Feature Toggles (Future Use)
# ============================================================================
# Enable/disable features for your specific event needs
# STEPPENREG_TEAMS_ENABLED=true
# STEPPENREG_DRAW_ENABLED=true
# STEPPENREG_WAITLIST_ENABLED=true
# STEPPENREG_STARTING_NUMBERS_ENABLED=true
# STEPPENREG_MAIL_TEMPLATES_ENABLED=true
